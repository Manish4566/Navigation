rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
        && data.keys().size() == 4
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 200
        && data.createdAt is timestamp;
    }

    // --- Connection Test ---
    match /public_health_check/{document} {
      allow get: if true;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().uid == userId
        && incoming().email is string
        && incoming().displayName is string
        && incoming().createdAt == request.time;
        
      allow update: if isOwner(userId)
        && incoming().uid == userId
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'updatedAt'])
        );
    }

    // --- Chat Session Validation ---
    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt'])
        && data.keys().size() == 4
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // --- Chat Sessions Collection ---
    match /chat_sessions/{sessionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(sessionId)
        && isValidSession(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && existing().userId == request.auth.uid
        && isValidSession(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt'])
          || incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt'])
        );

      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || request.auth.uid != null);

      // --- Message Validation ---
      function isValidMessage(data) {
        return data.keys().hasAll(['sessionId', 'role', 'content', 'createdAt'])
          && data.keys().size() == 4
          && data.sessionId == sessionId
          && data.role in ['user', 'model', 'system']
          && data.content is string && data.content.size() <= 20000
          && data.createdAt is timestamp;
      }

      // --- Messages Sub-collection ---
      match /messages/{messageId} {
        function belongsToUser() {
          return get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.userId == request.auth.uid;
        }

        allow list: if isSignedIn() && belongsToUser();
        allow get: if isSignedIn() && belongsToUser();

        allow create: if isSignedIn()
          && belongsToUser()
          && isValidId(messageId)
          && isValidMessage(incoming())
          && incoming().createdAt == request.time;

        allow update, delete: if false;
      }
    }
  }
}
